# Trade Tycoon server — environment variables
#
# When REDIS_URL is set, the server uses Upstash Redis for room state and
# pub/sub fan-out. This is required in any multi-instance deployment (Vercel
# serverless, multiple replicas behind a load balancer, etc.) — without it,
# rooms only live inside a single process and concurrent clients get
# inconsistent views.
#
# When REDIS_URL is not set, the server uses an in-memory store + bus.
# Useful for local single-process development and tests.
#
# Format (Upstash provides this on the database's "Connect" page,
# under "TLS connection"):
#   REDIS_URL=rediss://default:<password>@<host>:<port>
#
# rediss:// (with the extra 's') means TLS, which Upstash requires.
REDIS_URL=

# Port to listen on for local dev. Vercel ignores this — its runtime sets PORT
# itself. Defaults to 3001.
PORT=3001
