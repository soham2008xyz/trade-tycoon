{
  "name": "@trade-tycoon/client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "vitest run components",
    "build": "npm run build:web",
    "build:web": "expo export --platform web",
    "generate:pwa": "node ./scripts/generate-pwa-assets.js && node ./scripts/generate-sw.js",
    "vercel-build": "npm run build:web && npm run generate:pwa",
    "serve:dist": "npm run build && serve ./dist"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.4",
    "@react-navigation/native": "^7.1.8",
    "@trade-tycoon/game-logic": "^1.0.0",
    "expo": "^55.0.23",
    "expo-constants": "~55.0.16",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-screen-orientation": "~55.0.14",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.17",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~55.0.0",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "workbox-build": "^7.4.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "private": true
}
