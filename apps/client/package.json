{
  "name": "@trade-tycoon/client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run build:web",
    "build:web": "expo export --platform web",
    "generate:pwa": "node ./scripts/generate-pwa-assets.js && node ./scripts/generate-sw.js",
    "vercel-build": "npm run build:web && npm run generate:pwa",
    "serve:dist": "npm run build && serve ./dist"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/slider": "5.2.0",
    "@trade-tycoon/game-logic": "^1.0.0",
    "expo": "^56.0.8",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-screen-orientation": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~56.0.4",
    "serve": "^14.2.5",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "workbox-build": "^7.4.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "private": true
}
