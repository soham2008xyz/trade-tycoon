{
  "name": "trade-tycoon-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently --names \"api,web\" --prefix-colors \"blue,green\" --kill-others-on-fail \"npm run server\" \"npm run web\"",
    "start:native": "concurrently --names \"api,native\" --prefix-colors \"blue,magenta\" --kill-others-on-fail \"npm run server\" \"npm run start --workspace=apps/client\"",
    "start:server": "npm run server",
    "server": "npm run dev --workspace=apps/server",
    "web": "npm run web --workspace=apps/client",
    "build:game-logic": "npm run build --workspace=packages/game-logic",
    "build": "npm run build --workspaces --if-present",
    "vercel-build": "npm run vercel-build --workspace=apps/client",
    "export": "npm run vercel-build --workspace=apps/client",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspace=apps/client",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "prepare": "husky",
    "format": "prettier --write **/*.{js,ts,tsx,json,md}"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "expo-router": "~56.2.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": "prettier --write"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.4.1",
    "react-native-screens": "~4.25.1",
    "react-native-worklets": "0.8.3",
    "react-native-safe-area-context": "~5.8.0",
    "@types/react": "~19.2.14"
  }
}
